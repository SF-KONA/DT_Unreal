# ============================================================
# Unreal Engine 5.7 .gitignore
# 프로젝트: 셀 의장 공정 디지털트윈
# ============================================================

# ============================================================
# Unreal Engine 빌드/임시 파일 (반드시 제외)
# ============================================================
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# 셰이더 캐시
*.tmp
*.log
*.pdb

# ============================================================
# Visual Studio 관련
# ============================================================
.vs/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.user
*.userosscache
*.usertasks

# Visual Studio Code
.vscode/

# JetBrains Rider
.idea/
*.iml

# ============================================================
# Visual Studio 빌드 결과물 (혹시 모를 경우)
# ============================================================
[Bb]in/
[Oo]bj/
*.dll
*.exe
*.pdb

# ============================================================
# 운영체제 시스템 파일
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================================
# 임시/백업 파일
# ============================================================
*.bak
*.backup
*.swp
*.swo
*~
*.tmp
*.cache
*.orig

# ============================================================
# 패키징/배포 결과물
# ============================================================
Packaged/
PackagedBuilds/
Cooked/
Build/

# ============================================================
# 사용자 개인 설정 (각자 PC 환경별)
# ============================================================
Config/DefaultEditorPerProjectUserSettings.ini
Config/UserAutoBuild.ini

# ============================================================
# 압축 파일 (필요한 경우만 별도 push)
# ============================================================
*.zip
*.rar
*.7z

# ============================================================
# 보안 관련 파일 (절대 push 금지)
# ============================================================
*.env
secrets.txt
credentials.json
*.pem
*.key

# ============================================================
# 문서 작업 임시 파일
# ============================================================
~$*.docx
~$*.xlsx
~$*.pptx

# ============================================================
# Python 캐시 (외부 스크립트 사용 시)
# ============================================================
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ============================================================
# 로그 파일
# ============================================================
*.log
Logs/

# ============================================================
# 미디어 임시 파일 (편집 중)
# ============================================================
*.psd~
*.ai~
